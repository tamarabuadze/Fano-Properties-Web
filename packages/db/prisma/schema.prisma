generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  agent
  user
}

enum PropertyType {
  apartment
  villa
  house
  commercial
  land
  penthouse
  townhouse
}

enum ListingType {
  sale
  rent
  lease
}

enum PropertyStatus {
  available
  sold
  rented
  off_market
}

enum InquiryStatus {
  new
  contacted
  in_progress
  closed
}

enum InquiryType {
  property
  agent
  general
  callback
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  role        UserRole @default(user)
  firstName   String?
  lastName    String?
  avatar      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent?
  inquiries   Inquiry[]

  @@map("users")
}

model Agent {
  id                String    @id @default(cuid())
  userId            String?   @unique
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName         String
  lastName          String
  slug              String    @unique
  email             String    @unique
  phone             String?
  bio               String?   @db.Text
  avatar            String?
  title             String?
  specialization    String?
  licenseNumber     String?
  yearsExperience   Int?
  languages         String[]  @default([])
  linkedinUrl       String?
  instagramUrl      String?
  twitterUrl        String?
  facebookUrl       String?
  websiteUrl        String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  properties        Property[]
  inquiries         Inquiry[]

  @@map("agents")
}

model Property {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  propertyType    PropertyType
  listingType     ListingType
  status          PropertyStatus  @default(available)
  price           Decimal         @db.Decimal(15, 2)
  currency        String          @default("USD")
  location        String
  city            String
  state           String?
  country         String          @default("US")
  postalCode      String?
  bedrooms        Int             @default(0)
  bathrooms       Int             @default(0)
  sqft            Int             @default(0)
  amenities       String[]        @default([])
  coverImage      String
  featured        Boolean         @default(false)
  published       Boolean         @default(false)
  lat             Decimal?        @db.Decimal(10, 8)
  lng             Decimal?        @db.Decimal(11, 8)
  metaTitle       String?
  metaDescription String?
  viewCount       Int             @default(0)
  agentId         String?
  agent           Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  images          PropertyImage[]
  inquiries       Inquiry[]

  @@index([slug])
  @@index([featured, published])
  @@index([city, propertyType, listingType])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url         String
  alt         String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

model BlogCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  articles    BlogArticle[]

  @@map("blog_categories")
}

model BlogTag {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())

  articles  BlogArticleTag[]

  @@map("blog_tags")
}

model BlogArticle {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  excerpt         String
  content         String           @db.Text
  coverImage      String?
  published       Boolean          @default(false)
  publishedAt     DateTime?
  readTime        Int?
  categoryId      String?
  category        BlogCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId        String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  viewCount       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tags            BlogArticleTag[]

  @@index([slug])
  @@index([published, publishedAt])
  @@map("blog_articles")
}

model BlogArticleTag {
  articleId String
  tagId     String
  article   BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       BlogTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("blog_article_tags")
}

model Inquiry {
  id         String        @id @default(cuid())
  type       InquiryType   @default(general)
  status     InquiryStatus @default(new)
  firstName  String
  lastName   String
  email      String
  phone      String?
  message    String        @db.Text
  propertyId String?
  property   Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  agentId    String?
  agent      Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes      String?       @db.Text
  readAt     DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status, createdAt])
  @@map("inquiries")
}

model SiteSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @db.Text
  description     String?
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}
